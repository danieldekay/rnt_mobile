/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; img-src 'self' data: https://*.tile.openstreetmap.org https://*.rhein-neckar-tango.de https://*.wp.com; connect-src 'self' https://www.rhein-neckar-tango.de; font-src 'self' data: https://fonts.gstatic.com; frame-ancestors 'self'; form-action 'self'; base-uri 'self'; object-src 'none'
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Cache-Control: public, max-age=0, must-revalidate
  X-XSS-Protection: 1; mode=block